	"quest.1D5A582F52D7CB30.quest_desc": [
		"Craft a leather-tier Sophisticated Backpack. Any dye color counts — they all share the same item ID.",
		"",
		"Recipe: leather, string, and a wooden chest.",
		"",
		"Right-click to open it, shift-right-click to equip it, and add upgrades later to automate pickup, crafting, and more.",
